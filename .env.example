# LekoAIFinance — variáveis de ambiente
# Copie este arquivo para ".env" e preencha com seus valores reais.
# NUNCA versione o .env (ele já está no .gitignore).

# Token do bot do Telegram (obtido com o @BotFather)
TELEGRAM_BOT_TOKEN=

# Projeto Supabase (Fonte da Verdade)
SUPABASE_URL=
SUPABASE_KEY=

# Chave da API Groq (Camada 2 - IA). Crie em https://console.groq.com/keys
GROQ_API_KEY=
